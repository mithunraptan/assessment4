<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>web-demo-upgrade</display-name>
  <welcome-file-list>
    <welcome-file>login.jsp</welcome-file>
  </welcome-file-list>
  
     <servlet>
        <servlet-name>AdminLoginServlet</servlet-name>
        <servlet-class>com.training.servlet.AdminLoginServlet</servlet-class>
    </servlet>
 
  <servlet-mapping>
        <servlet-name>AdminLoginServlet</servlet-name>
        <url-pattern>/adminLogin</url-pattern>
    </servlet-mapping>

 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
 
  
  
  <!-- Servlet Declaration -->
   <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.training.servlet.LogoutServlet</servlet-class>
    </servlet>
  <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.training.servlet.SignupServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.training.servlet.LoginServlet</servlet-class>
    </servlet>

    <!-- Servlet Mapping -->
     <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>
    
    
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
      <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    
    <!-- Register Filter  -->
    <!-- context is for global value set for an entire application -->
    <context-param>
    	<param-name>filterCounter</param-name>
    	<param-value>0</param-value>
    </context-param>
    
    <filter>
    	<filter-name>LogginFilter</filter-name>
    	<filter-class>com.training.filter.LogginFilter</filter-class>
    </filter>
    <filter-mapping>
    	<filter-name>LogginFilter</filter-name>
    	<url-pattern>/*</url-pattern>
    </filter-mapping>
    
    
    

    
</web-app>